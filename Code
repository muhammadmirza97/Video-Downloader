# Import the YouTube class from pytube
from pytube import YouTube

# Ask the user to enter a YouTube video URL
video_url = input("Enter YouTube video URL: ")

# Create a YouTube object using the URL
yt = YouTube(video_url)

# Display video title to confirm correct video
print(f"Downloading: {yt.title}")

# Get the highest resolution progressive stream
# (progressive = video + audio together)
video = yt.streams.get_highest_resolution()

# Download the video to the current folder
video.download()

# Notify user when download is complete
print("Download completed successfully!")
